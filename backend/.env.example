QDRANT_URL=
QDRANT_API_KEY=
EMBEDDING_API_BASE_URL=http://<VM_IP>:8000

# ── LLM Provider ──────────────────────────────────────────
# Backend selection: "gemini" (default) | "openai_compat" | "llama_cpp"
LLM_BACKEND=gemini

# Required for gemini backend:
GEMINI_API_KEY=

# Required for openai_compat / llama_cpp backend:
# LLM_BASE_URL=http://localhost:8080
# LLM_API_KEY=
# LLM_MODEL_NAME=
