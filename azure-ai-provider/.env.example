# ══════════════════════════════════════════════════════════════════════════════
# Azure AI Provider — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════

# HuggingFace token (for gated model downloads)
HF_TOKEN=hf_your_token_here

# LLM Service (vLLM)
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_PORT=8000
LLM_MAX_MODEL_LEN=4096

# Embedding Service
EMBEDDING_PORT=8001

# API Gateway
GATEWAY_PORT=8080

# Timeouts (seconds)
GATEWAY_TIMEOUT=5
